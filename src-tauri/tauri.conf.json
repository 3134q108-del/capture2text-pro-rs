{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Capture2Text Pro",
  "version": "0.3.0",
  "identifier": "com.capture2text.pro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Capture2Text Pro",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "result",
        "title": "Capture2Text - OCR Text",
        "width": 415,
        "height": 403,
        "visible": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "decorations": true,
        "resizable": true,
        "focus": false,
        "minWidth": 360,
        "minHeight": 180
      },
      {
        "label": "settings",
        "title": "設定 - Capture2Text",
        "width": 846,
        "height": 551,
        "visible": false,
        "skipTaskbar": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Capture2Text Pro",
    "shortDescription": "Windows 桌面 OCR + 翻譯 + Azure TTS 朗讀",
    "longDescription": "按 Win+Q 截圖即時 OCR + 翻譯,Qwen3-VL 8B 本機 7 語(繁中/簡中/英/日/韓/德/法),選用 Azure TTS BYOK 朗讀。",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": [
          "TradChinese",
          "English"
        ],
        "installerHooks": "./windows/installer.nsh"
      }
    }
  }
}
