{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "capture2text-pro-rs",
  "version": "0.1.0",
  "identifier": "com.capture2text.pro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "capture2text-pro-rs",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "result",
        "title": "Capture2Text - OCR Text",
        "width": 661,
        "height": 371,
        "visible": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "decorations": true,
        "resizable": true,
        "focus": false,
        "minWidth": 360,
        "minHeight": 180
      },
      {
        "label": "settings",
        "title": "設定 - Capture2Text",
        "width": 700,
        "height": 500,
        "visible": false,
        "skipTaskbar": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Capture2Text Pro",
    "shortDescription": "Windows OCR + 翻譯 + 朗讀工具",
    "longDescription": "按 Win+Q/W/E 截圖文字，本機 Qwen3-VL 即時翻譯、Edge TTS 朗讀。",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": [
          "TradChinese",
          "English"
        ]
      }
    }
  }
}
